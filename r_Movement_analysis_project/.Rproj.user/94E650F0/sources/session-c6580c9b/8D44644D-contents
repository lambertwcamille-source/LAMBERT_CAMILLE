# Analysis 2 — Effect of sensor location within each FAC group

For each FAC group (using Scheme B since it has more subjects per group), we test whether the 5 sensors give different cadence estimates. This directly tests the hypothesis that sensor placement matters in low FAC but not in high FAC.

Each group is analyzed with:

1. **Repeated-measures ANOVA** — parametric, for the headline result
2. **Shapiro-Wilk** on residuals — to diagnose normality
3. **Friedman test** — non-parametric backup
4. **Pairwise Bonferroni post-hoc** for both tests

## Analysis function

```{r anova-pergroup-function}
analyze_sensor_effect <- function(df_group, subject_var, group_label) {
  cat("\n", strrep("-", 72), "\n", sep = "")
  cat("  Group: ", group_label, "\n", sep = "")
  cat(strrep("-", 72), "\n", sep = "")

  # Exclude samples with missing sensors & keep only complete samples
  df_group <- df_group %>%
    filter(!(sample_id %in% samples_to_exclude))
  ok_samples <- df_group %>%
    count(sample_id) %>%
    filter(n == 5) %>%
    pull(sample_id)
  df_group <- df_group %>% filter(sample_id %in% ok_samples)

  n_subj <- n_distinct(df_group[[subject_var]])
  cat("  n subjects:", n_subj, "\n\n")

  if (n_subj < 2) {
    cat("  /!\\ Need at least 2 subjects, group skipped.\n")
    return(NULL)
  }

  out <- list(group = group_label, n = n_subj)

  # 1. Repeated-measures ANOVA
  cat("-- Repeated-measures ANOVA (cadence ~ sensor) --\n")
  rm_anova <- tryCatch({
    aov_ez(
      id = subject_var, dv = "cadence", data = df_group,
      within = "sensor",
      anova_table = list(correction = "GG", es = "pes")
    )
  }, error = function(e) {
    cat("  /!\\ Failed:", conditionMessage(e), "\n")
    return(NULL)
  })

  if (!is.null(rm_anova)) {
    print(rm_anova)
    anova_tab <- as.data.frame(rm_anova$anova_table)
    out$F_anova   <- anova_tab[1, "F"]
    out$p_anova   <- anova_tab[1, "Pr(>F)"]
    out$pes_anova <- anova_tab[1, "pes"]

    # Post-hoc Bonferroni on sensors
    cat("\n-- Post-hoc: sensor pairs (Bonferroni) --\n")
    emm_s <- emmeans(rm_anova, ~ sensor)
    posthoc_s <- pairs(emm_s, adjust = "bonferroni")
    print(posthoc_s)

    # 2. Shapiro on residuals (only if n >= 3)
    if (n_subj >= 3) {
      resids <- residuals(rm_anova$lm)
      if (length(resids) >= 3) {
        sw <- shapiro.test(resids)
        cat(sprintf("\n-- Shapiro-Wilk on residuals: W = %.3f, p = %.4f --\n",
                    sw$statistic, sw$p.value))
        out$shapiro_p <- sw$p.value
        if (sw$p.value < 0.05) {
          cat("  => Normality rejected: prefer Friedman's result below.\n")
        } else {
          cat("  => Normality OK: ANOVA result is reliable.\n")
        }
      }
    } else {
      cat("\n-- Shapiro not computed (n < 3) --\n")
      out$shapiro_p <- NA_real_
    }
  }

  # 3. Friedman (non-parametric)
  # Use the wide-matrix form: rows = subjects, cols = sensors
  # This is the most robust form and avoids level-dropping issues.
  cat("\n-- Friedman test (non-parametric) --\n")
  fr <- tryCatch({
    df_fr <- df_group %>%
      select(all_of(subject_var), sensor, cadence) %>%
      pivot_wider(names_from = sensor, values_from = cadence) %>%
      select(-all_of(subject_var))     # drop subject column, keep only sensor matrix
    mat <- as.matrix(df_fr)
    # Sanity check: no NA, equal number of subjects in each column
    if (any(is.na(mat))) stop("Residual NA in Friedman matrix")
    friedman.test(mat)
  }, error = function(e) {
    cat("  /!\\ Failed:", conditionMessage(e), "\n")
    return(NULL)
  })

  if (!is.null(fr)) {
    print(fr)
    out$chi2_friedman <- as.numeric(fr$statistic)
    out$p_friedman    <- fr$p.value

    # Post-hoc: pairwise Wilcoxon signed-rank (Bonferroni)
    if (fr$p.value < 0.1) {
      cat("\n-- Post-hoc: pairwise Wilcoxon signed-rank (Bonferroni) --\n")
      ph <- pairwise.wilcox.test(
        df_group$cadence,
        droplevels(df_group$sensor),      # force drop of unused levels
        paired = TRUE, p.adjust.method = "bonferroni"
      )
      print(ph)
    }
  }

  return(out)
}
```

