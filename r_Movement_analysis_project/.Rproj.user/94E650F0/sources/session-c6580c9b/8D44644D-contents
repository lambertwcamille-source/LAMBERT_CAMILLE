  analysis = c(rep("Global mixed ANOVA\n(both visits, N=19)", 3),
               rep("Sensor effect\nper FAC group (both visits)", 3)),
  effect   = c("FAC group",
               "Sensor",
               "FAC \u00D7 Sensor",
               "Sensor in FAC 1-3 (n=3)",
