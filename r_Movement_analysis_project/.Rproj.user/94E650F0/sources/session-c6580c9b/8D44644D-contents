  scale_x_continuous(limits = c(0, 0.5), breaks = c(0, 0.01, 0.06, 0.14, 0.3, 0.5)) +
  labs(
    title    = "Effect sizes (partial \u03B7\u00B2) across analyses",
    subtitle = "Only the effect of FAC group reaches a large effect size and statistical significance.",
    x        = "Partial eta-squared (\u03B7\u00B2p)",
    y        = NULL,
    caption  = paste0(
      "Thresholds (Cohen): 0.01 small, 0.06 medium, 0.14 large.\n",
      "Note: non-significant effects with large \u03B7\u00B2p (e.g., Sensor in FAC 1-3) suggest possible effects\n",
      "masked by low statistical power (n=3). Interpret with caution."
    )
  ) +
  theme_thesis() +
  theme(legend.position = "bottom",
        panel.grid.major.y = element_blank())

ggsave(file.path(OUTPUT_DIR, "fig3_forest_effect_sizes.png"),
       p_forest, width = 8, height = 5, dpi = 150, bg = "white")
p_forest
