apply_FAC_grouping <- function(df) {
  df %>% mutate(
    FAC_group = factor(
      case_when(
        FAC %in% c(1, 2, 3) ~ "FAC1-3",
        FAC == 4            ~ "FAC4",
        FAC == 5            ~ "FAC5"
      ),
      levels = c("FAC1-3", "FAC4", "FAC5")
    )
  )
}
```

# Analysis 1 — Global mixed ANOVA

Tests the main effects of FAC_group and sensor, and their interaction. Uses Greenhouse-Geisser correction for sphericity (applied automatically by `afex::aov_ez`).

```{r anova-global-function}
run_mixed_anova <- function(df_long, subject_var, label) {
  cat("\n", strrep("=", 72), "\n", sep = "")
  cat("  ", label, "\n", sep = "")
  cat(strrep("=", 72), "\n\n", sep = "")

  # Drop samples with missing sensor data for this test
  df_long <- df_long %>% filter(!(sample_id %in% samples_to_exclude))

  # Keep only samples with ALL 5 sensors (balanced design for ANOVA mixte)
  ok_samples <- df_long %>%
    count(sample_id) %>%
    filter(n == 5) %>%
    pull(sample_id)
  df_long <- df_long %>% filter(sample_id %in% ok_samples)

  cat("-- Subjects per FAC group --\n")
  n_per_group <- df_long %>%
    distinct(!!sym(subject_var), FAC_group) %>%
    count(FAC_group, name = "n")
  print(n_per_group)
  cat("\n")

  # Mixed ANOVA
  anova_res <- tryCatch({
    aov_ez(
      id = subject_var, dv = "cadence", data = df_long,
      between = "FAC_group", within = "sensor",
      anova_table = list(correction = "GG", es = "pes")
    )
  }, error = function(e) {
    cat("/!\\ Mixed ANOVA failed:", conditionMessage(e), "\n")
    return(NULL)
  })

  if (is.null(anova_res)) return(invisible(NULL))

  print(anova_res)

  # Post-hoc FAC_group (Bonferroni)
  cat("\n-- Post-hoc: FAC_group (Bonferroni) --\n")
  emm <- emmeans(anova_res, ~ FAC_group)
  print(emm)
  cat("\n")
  print(pairs(emm, adjust = "bonferroni"))

  # Save
  out_tag <- gsub("[^A-Za-z0-9]", "_", label)
  saveRDS(anova_res, file.path(OUTPUT_DIR, paste0(out_tag, "_anova.rds")))

  invisible(anova_res)
}
```

