## Define the two FAC grouping schemes

```{r anova-schemas}
apply_schema_A <- function(df) {
  # {1+2} / {3} / {4} / {5}  ->  4 groups
  df %>% mutate(
    FAC_group = factor(
      case_when(
        FAC %in% c(1, 2) ~ "FAC1-2",
        FAC == 3         ~ "FAC3",
        FAC == 4         ~ "FAC4",
        FAC == 5         ~ "FAC5"
      ),
      levels = c("FAC1-2", "FAC3", "FAC4", "FAC5")
    )
  )
}

apply_schema_B <- function(df) {
  # {1+2+3} / {4} / {5}  ->  3 groups
  df %>% mutate(
    FAC_group = factor(
      case_when(
        FAC %in% c(1, 2, 3) ~ "FAC1-3",
        FAC == 4            ~ "FAC4",
        FAC == 5            ~ "FAC5"
      ),
      levels = c("FAC1-3", "FAC4", "FAC5")
    )
  )
}
```

## Mixed ANOVA function

This function runs the complete analysis: checks, ANOVA, post-hoc, and returns a summary tibble.

```{r anova-function}
run_mixed_anova <- function(df_long, subject_var, label) {
  cat("\n", strrep("=", 72), "\n", sep = "")
  cat("  ANALYSIS: ", label, "\n", sep = "")
  cat(strrep("=", 72), "\n\n", sep = "")

  # Group sizes
  cat("-- Sample sizes per FAC group --\n")
  n_per_group <- df_long %>%
    distinct(!!sym(subject_var), FAC_group) %>%
    count(FAC_group, name = "n_subjects")
  print(n_per_group)
  cat("\n")

  # Shapiro-Wilk normality by cell (only where n >= 3)
  cat("-- Shapiro-Wilk normality per FAC_group x sensor --\n")
  sw_results <- df_long %>%
    group_by(FAC_group, sensor) %>%
    summarise(
      n = n(),
      W = if (n() >= 3) shapiro.test(cadence)$statistic else NA_real_,
      p = if (n() >= 3) shapiro.test(cadence)$p.value   else NA_real_,
      .groups = "drop"
    )
  print(sw_results, n = Inf)
  cat("\n")

  # Mixed ANOVA via afex::aov_ez
  # Greenhouse-Geisser correction for sphericity, partial eta-squared
  cat("-- Mixed ANOVA --\n")
  cat("  Formula: cadence ~ FAC_group * sensor + Error(", subject_var,
      "/sensor)\n", sep = "")

  anova_res <- tryCatch({
    aov_ez(
      id       = subject_var,
      dv       = "cadence",
      data     = df_long,
      between  = "FAC_group",
      within   = "sensor",
      anova_table = list(correction = "GG", es = "pes")
    )
  }, error = function(e) {
    cat("  /!\\ Mixed ANOVA failed: ", conditionMessage(e), "\n", sep = "")
    cat("  Likely cause: n=1 in a group, or extreme imbalance.\n")
    return(NULL)
  })

  if (is.null(anova_res)) return(NULL)
  print(anova_res)

  # Post-hoc: pairwise FAC_group (averaged over sensors), Bonferroni
  cat("\n-- Post-hoc: FAC_group pairwise (Bonferroni) --\n")
  emm <- emmeans(anova_res, ~ FAC_group)
  print(emm)
  cat("\n")
  posthoc <- pairs(emm, adjust = "bonferroni")
  print(posthoc)

  # Post-hoc on interaction
  cat("\n-- Interaction post-hoc: FAC_group within each sensor (Bonferroni) --\n")
  emm_int <- emmeans(anova_res, ~ FAC_group | sensor)
  posthoc_int <- pairs(emm_int, adjust = "bonferroni")
  print(summary(posthoc_int))

  # Compact summary for comparison table
  anova_table <- as.data.frame(anova_res$anova_table)
  summary_df <- tibble(
    analysis   = label,
    n_obs      = nrow(df_long),
    n_subjects = n_distinct(df_long[[subject_var]]),
    n_groups   = n_distinct(df_long$FAC_group),
    F_FAC      = anova_table["FAC_group", "F"],
    p_FAC      = anova_table["FAC_group", "Pr(>F)"],
    pes_FAC    = anova_table["FAC_group", "pes"],
    F_sensor   = anova_table["sensor", "F"],
    p_sensor   = anova_table["sensor", "Pr(>F)"],
    pes_sensor = anova_table["sensor", "pes"],
    F_inter    = anova_table["FAC_group:sensor", "F"],
    p_inter    = anova_table["FAC_group:sensor", "Pr(>F)"],
    pes_inter  = anova_table["FAC_group:sensor", "pes"]
  )

  # Save per-analysis artifacts
  out_tag <- gsub("[^A-Za-z0-9]", "_", label)
  write_csv(sw_results, file.path(OUTPUT_DIR, paste0(out_tag, "_shapiro.csv")))
  saveRDS(anova_res, file = file.path(OUTPUT_DIR, paste0(out_tag, "_anova.rds")))
  write_csv(as.data.frame(summary(posthoc)),
            file.path(OUTPUT_DIR, paste0(out_tag, "_posthoc_FAC.csv")))
  write_csv(as.data.frame(summary(posthoc_int)),
            file.path(OUTPUT_DIR, paste0(out_tag, "_posthoc_FACxsensor.csv")))

  return(summary_df)
}
```

## Run the 4 analyses

### Mode 1 — visit1 only

```{r anova-run-visit1}
df_v1 <- df_long %>% filter(visit == "visit1")

res_A_v1 <- run_mixed_anova(
  df_v1 %>% apply_schema_A(),
  subject_var = "patient_id",
  label       = "Scheme A (FAC1-2/3/4/5) - visit1 only"
)

res_B_v1 <- run_mixed_anova(
  df_v1 %>% apply_schema_B(),
  subject_var = "patient_id",
  label       = "Scheme B (FAC1-3/4/5) - visit1 only"
)
```

### Mode 2 — both visits (sample_id as subject)

Each (patient × visit) is treated as an independent sample. This is an approximation — justified by the ~1-2 week interval between visits and documented clinical evolution for several patients.

```{r anova-run-allvisits}
res_A_all <- run_mixed_anova(
  df_long %>% apply_schema_A(),
  subject_var = "sample_id",
  label       = "Scheme A (FAC1-2/3/4/5) - both visits"
)

res_B_all <- run_mixed_anova(
  df_long %>% apply_schema_B(),
  subject_var = "sample_id",
  label       = "Scheme B (FAC1-3/4/5) - both visits"
)
```

