TRUE                                ~ NA_character_
)
)
# Aperçu pour vérifier
df_test %>% select(visit, sensor, peak_frequency_hz, group)
# T-test (par défaut Welch, ne suppose pas l'égalité des variances)
t_test_result <- t.test(
