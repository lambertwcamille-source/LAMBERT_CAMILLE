if (!requireNamespace(pkg, quietly = TRUE)) install.packages(pkg)
# Use the normalized path to selection the good directory
project_root <- normalizePath("..")
results_dir  <- file.path(project_root, "results")
frequency_summary<- file.path(results_dir, "frequency_summary.csv")
# load the data frame of the frequency summary
df_frequency_summary <- read_csv(frequency_summary, show_col_types = FALSE)
(df_frequency_summary)
# Make a t-test to visualise the difference between the feet and the other sensor (wrist and sacrum)
t_test_sacrum <- df_frequency_summary %>%
filter(sensor == "SA") %>%
pull(frequency)
# Make the data frame for the t-test
df_sacrum_vs_feet <- df_frequency_summary %>%
filter(sensor %in% c("SA", "LF", "RF")) %>%
select(patient_id, sensor, fundamental_frequency)
required_packages <- c("tidyverse", "afex", "emmeans", "rstatix", "ggpubr")
for (pkg in required_packages) {
if (!requireNamespace(pkg, quietly = TRUE)) install.packages(pkg)
}
library(tidyverse)
library(afex)
library(emmeans)
library(rstatix)
library(ggpubr)
library(dplyr)
library(tidyr)
library(overlapping)
# if neded, install the packages
# install.packages("tidyverse")
# install.packages("afex")
# install.packages("emmeans")
# install.packages("rstatix")
# install.packages("ggpubr")
# install.packages("dplyr")
# install.packages("tidyr")
# install.packages("overlapping")
# Make the data frame for the t-test
df_sacrum_vs_feet <- df_frequency_summary %>%
filter(sensor %in% c("SA", "LF", "RF")) %>%
select(visit, sensor, fundamental_frequency)
# Make the data frame for the t-test
df_sacrum_vs_feet <- df_frequency_summary %>%
filter(sensor %in% c("SA", "LF", "RF")) %>%
select(visit, sensor, peak_frequency_hz)
df_wrist_vs_feet <- df_frequency_summary %>%
filter(sensor %in% c("LW", "LF", "RW", "RF")) %>%
select(visit, sensor, peak_frequency_hz)
# T-test between the sacrum and the feet
t_test_sacrum_vs_feet <- df_sacrum_vs_feet %>%
t_test(peak_frequency_hz ~ sensor, paired = TRUE) %>%
add_significance()
print(t_test_sacrum_vs_feet)
# T-test between the wrist and the feet
t_test_wrist_vs_feet <- df_wrist_vs_feet %>%
t_test(peak_frequency_hz ~ sensor, paired = TRUE) %>%
add_significance()
print(t_test_wrist_vs_feet)
# Make the data frame for the t-test
df_sacrum_vs_feet <- df_frequency_summary %>%
filter(sensor %in% c("SA", "LF", "RF")) %>%
select(sensor, peak_frequency_hz)
df_wrist_vs_feet <- df_frequency_summary %>%
filter(sensor %in% c("LW", "LF", "RW", "RF")) %>%
select(sensor, peak_frequency_hz)
# T-test between the sacrum and the feet
t_test_sacrum_vs_feet <- df_sacrum_vs_feet %>%
t_test(peak_frequency_hz ~ sensor, paired = TRUE) %>%
add_significance()
print(t_test_sacrum_vs_feet)
# T-test between the wrist and the feet
t_test_wrist_vs_feet <- df_wrist_vs_feet %>%
t_test(peak_frequency_hz ~ sensor, paired = TRUE) %>%
add_significance()
print(t_test_wrist_vs_feet)
## Step 3: T-test between the feet and the other sensors
# Créer un groupe "feet" (LF, RF) vs "other" (LW, RW, SA)
df_test <- df_frequency_summary %>%
mutate(
group = case_when(
sensor %in% c("LF", "RF")          ~ "feet",
sensor %in% c("LW", "RW", "SA")    ~ "other",
TRUE                                ~ NA_character_
)
)
# Aperçu pour vérifier
df_test %>% select(visit, sensor, peak_frequency_hz, group)
# T-test (par défaut Welch, ne suppose pas l'égalité des variances)
t_test_result <- t.test(
peak_frequency_hz ~ group,
data = df_test
)
print(t_test_result)
## Step 3: T-test between the feet and the other sensors
