required_packages <- c("tidyverse", "afex", "emmeans", "rstatix", "ggpubr")
for (pkg in required_packages) {
if (!requireNamespace(pkg, quietly = TRUE)) install.packages(pkg)
}
library(tidyverse)
library(afex)
library(emmeans)
library(rstatix)
library(ggpubr)
library(dplyr)
library(tidyr)
library(overlapping)
