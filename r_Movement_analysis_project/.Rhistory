ggplot(aes(x = sensor, y = delta, color = sensor)) +
# Add jitter to the points to avoid overplotting
geom_jitter(width = 0.2, alpha = 0.7, size = 2) +
# Add a horizontal line at y = 0 to indicate no difference
geom_hline(yintercept = 0, linetype = "dashed", color = "grey40") +
labs(
title = "Distribution of delta (cadence - cadence_RF) by sensor",
y = "frequency_delta (Hz)",
x = "Sensor"
) +
theme_minimal()+
theme(legend.position = "none")    # hyde the legend this the x are alreafy informative
plot(delta_scatter)
