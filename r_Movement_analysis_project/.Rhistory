df_icc %
# Reshape the data: one row per visit, one column per sensor
df_icc <- df_frequency_summary %>%
select(visit, sensor, peak_frequency_hz) %>%
pivot_wider(names_from = sensor, values_from = peak_frequency_hz) %>%
select(-visit)   # keep only the numeric columns for ICC
df_icc
# ICC: two-way mixed, absolute agreement, single measure
icc_result <- icc(df_icc,
model = "twoway",
type  = "agreement",
unit  = "single")
icc_result
```{r rank-tests, message=FALSE, warning=FALSE}
# df_icc est déjà au bon format : matrice 2 visites × 5 capteurs
# Lignes = sujets (visites), colonnes = juges (capteurs)
# Test de Friedman : les capteurs donnent-ils des fréquences différentes ?
friedman_result <- friedman.test(as.matrix(df_icc))
friedman_result
# Coefficient de concordance de Kendall : accord entre capteurs
# Note : Kendall W attend l'inverse — lignes = objets jugés, colonnes = juges
# Ici, "objets" = visites, "juges" = capteurs → df_icc est déjà bon
kendall_result <- kendall(df_icc, correct = TRUE)
kendall_result
# df_icc est déjà au bon format : matrice 2 visites × 5 capteurs
# Lignes = sujets (visites), colonnes = juges (capteurs)
# Test de Friedman : les capteurs donnent-ils des fréquences différentes ?
friedman_result <- friedman.test(as.matrix(df_icc))
friedman_result
